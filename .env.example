# ===== HR 提效智能体 环境变量示例 =====
# 复制本文件为 .env 后填写。绝对不要把 .env 提交到 git。
#
#   cp .env.example .env      (Windows PowerShell: Copy-Item .env.example .env)
#
# ------------------------------------------------------------------
# 【重要】不填任何 KEY 也能运行！
# 不配置 LLM_API_KEY 时，系统自动进入「离线 Mock 模式」，
# 用内置启发式规则模拟大模型输出，整条流水线照常跑通，方便零基础演示。
# 配置了真实 KEY 后，自动切换为真实大模型调用。
# ------------------------------------------------------------------

# 大模型提供方: deepseek / openai / qwen / moonshot / custom
LLM_PROVIDER=deepseek

# API Key（留空 = 离线 Mock 模式）
LLM_API_KEY=

# OpenAI 兼容的 base_url。常用值：
#   DeepSeek : https://api.deepseek.com/v1
#   OpenAI   : https://api.openai.com/v1
#   通义千问  : https://dashscope.aliyuncs.com/compatible-mode/v1
#   Moonshot : https://api.moonshot.cn/v1
LLM_BASE_URL=https://api.deepseek.com/v1

# 模型名
LLM_MODEL=deepseek-chat

# 采样温度（信息抽取/评分建议用低温度，保证稳定）
LLM_TEMPERATURE=0.2

# 单次请求超时（秒）
LLM_TIMEOUT=60

# ---- 数据与输出目录（一般无需修改）----
DATABASE_URL=sqlite:///./hr_agent.db
OUTPUT_DIR=./outputs

# ---- 后续集成预留（第一版可全部留空）----
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_APP_TOKEN=
COZE_API_TOKEN=
COZE_WORKFLOW_ID=
WECHAT_WORK_WEBHOOK=
